# Split panes: prefix + | for vertical, prefix + - for horizontal
bind \\ split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Use vim keys in copy/scroll mode
setw -g mode-keys vi

# Colors
set -g window-style "bg=#0a0a0a"
set -g window-active-style "bg=#000000"
set -g pane-border-style "fg=#333333,bg=#0a0a0a"
set -g pane-active-border-style "fg=green,bg=#000000"

# Extended keys (for Ctrl+Shift distinction)
set -s extended-keys on
set -s extended-keys-format csi-u
set -as terminal-features 'xterm*:extkeys'

# Mouse
set -g mouse on

# Move panes (Ctrl + h/j/k/l)
bind -n C-h select-pane -L
bind -n C-j select-pane -D
bind -n C-k select-pane -U
bind -n C-l select-pane -R

# Resize panes (Ctrl+Option + h/j/k/l)
bind -n C-M-h resize-pane -L 5
bind -n C-M-j resize-pane -D 5
bind -n C-M-k resize-pane -U 5
bind -n C-M-l resize-pane -R 5

# ── Status bar ──────────────────────────────────────────
set -g status-position bottom
set -g status-style 'bg=#1a1b26 fg=#a9b1d6'
set -g status-interval 5

# Left: session name with accent
set -g status-left '#[fg=#1a1b26,bg=#7aa2f7,bold]  #S #[fg=#7aa2f7,bg=#1a1b26,nobold] '
set -g status-left-length 30

# Right: minimal
set -g status-right '#[fg=#565f89] %H:%M '

# Window tabs
set -g window-status-format '#[fg=#565f89,bg=#1a1b26]  #I #W  '
set -g window-status-current-format '#[fg=#1a1b26,bg=#3b4261]#[fg=#c0caf5,bg=#3b4261,bold] #I #W #[fg=#3b4261,bg=#1a1b26]'
set -g window-status-separator ''

# Message style
set -g message-style 'bg=#7aa2f7 fg=#1a1b26 bold'
# ── Status bar ──────────────────────────────────────────
