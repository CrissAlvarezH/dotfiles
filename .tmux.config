# Split panes: prefix + | for vertical, prefix + - for horizontal
bind \\ split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# New session: prefix + n
bind n new-session

# Rename session: prefix + r
bind r command-prompt "rename-session '%%'"

# Use vim keys in copy/scroll mode
setw -g mode-keys vi

# Colors
set -g pane-border-style "fg=#000000,bg=#000000"
set -g pane-active-border-style "fg=green,bg=#000000"

# Extended keys (for Ctrl+Shift distinction)
set -s extended-keys on
set -s extended-keys-format csi-u
set -as terminal-features 'xterm*:extkeys'

# Mouse
set -g mouse on

# Move panes (Ctrl + h/j/k/l)
bind -n C-h select-pane -L
bind -n C-j select-pane -D
bind -n C-k select-pane -U
bind -n C-l select-pane -R

# Resize panes (Ctrl+Shift + h/j/k/l)
bind -n C-H resize-pane -L 5
bind -n C-J resize-pane -D 5
bind -n C-K resize-pane -U 5
bind -n C-L resize-pane -R 5
